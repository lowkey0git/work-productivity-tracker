from fastapi import FastAPI, Depends, HTTPException, status
from fastapi.security import OAuth2PasswordRequestForm
from sqlalchemy.orm import Session
from . import models, schemas, crud, auth, ml_model
from .database import engine, SessionLocal
from .auth import create_access_token, ACCESS_TOKEN_EXPIRE_MINUTES
from datetime import timedelta
import secrets
from fastapi.middleware.cors import CORSMiddleware

models.Base.metadata.create_all(bind=engine)

app = FastAPI(title="WorkTracker API")

# Allow local frontend
app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000", "*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Dependency
def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()

# Token endpoint
@app.post("/api/token", response_model=schemas.Token)
def login_for_access_token(form_data: OAuth2PasswordRequestForm = Depends(), db: Session = Depends(get_db)):
    manager = auth.authenticate_manager(db, form_data.username, form_data.password)
    if not manager:
        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail="Incorrect username or password")
    access_token_expires = timedelta(minutes=ACCESS_TOKEN_EXPIRE_MINUTES)
    access_token = create_access_token(data={"sub": manager.username}, expires_delta=access_token_expires)
    return {"access_token": access_token, "token_type": "bearer"}

# Create initial manager (should be run once or admin-managed)
@app.post("/api/manager/create", response_model=schemas.ManagerOut)
def create_manager(m: schemas.ManagerCreate, db: Session = Depends(get_db)):
    existing = crud.get_manager_by_username(db, m.username)
    if existing:
        raise HTTPException(status_code=400, detail="Manager already exists")
    manager = crud.create_manager(db, m.username, m.password, m.email)
    return manager

# Password reset request -> generate token and persist
@app.post("/api/manager/request-reset")
def request_reset(req: schemas.PasswordResetRequest, db: Session = Depends(get_db)):
    manager = crud.get_manager_by_username(db, req.username)
    if not manager:
        raise HTTPException(status_code=404, detail="Manager not found")
    token = secrets.token_urlsafe(16)
    crud.set_reset_token(db, manager, token)
    # In production: email token to manager.email. For demo return token.
    return {"reset_token": token, "note": "In production email this token; here it's returned for convenience."}

# Confirm reset
@app.post("/api/manager/confirm-reset")
def confirm_reset(conf: schemas.PasswordResetConfirm, db: Session = Depends(get_db)):
    manager = crud.get_manager_by_username(db, conf.username)
    if not manager or manager.reset_token != conf.reset_token:
        raise HTTPException(status_code=400, detail="Invalid token or username")
    from passlib.context import CryptContext
    pwd = CryptContext(schemes=["bcrypt"], deprecated="auto")
    hashed = pwd.hash(conf.new_password)
    crud.reset_password(db, conf.username, hashed)
    return {"detail": "Password reset successful"}

# Submit work entry
@app.post("/api/work", response_model=schemas.WorkEntryResponse)
def submit_work(entry: schemas.WorkEntryCreate, db: Session = Depends(get_db)):
    # run ML prediction
    # create a simple object with attributes expected by ml_model
    class _E: pass
    e = _E()
    e.amount_of_work = entry.amount_of_work
    e.duration_seconds = (entry.end_time - entry.start_time).total_seconds()
    pred = ml_model.predict_from_entry(e)
    created = crud.create_work_entry(db, entry, ml_prediction=pred)
    return created

# Get all entries (protected)
@app.get("/api/work", response_model=list[schemas.WorkEntryResponse])
def list_work_entries(skip: int = 0, limit: int = 100, db: Session = Depends(get_db), manager = Depends(auth.get_current_manager)):
    return crud.get_work_entries(db, skip=skip, limit=limit)

# Get aggregated statistics (protected)
@app.get("/api/stats")
def stats(db: Session = Depends(get_db), manager = Depends(auth.get_current_manager)):
    entries = crud.get_work_entries(db, skip=0, limit=10000)
    total = len(entries)
    total_work = sum(e.amount_of_work for e in entries)
    avg_duration = sum(e.duration_seconds for e in entries)/total if total else 0
    return {"total_entries": total, "total_work": total_work, "avg_duration_seconds": avg_duration}

# Endpoint to trigger model training from stored entries (protected)
@app.post("/api/train-model")
def train_model(db: Session = Depends(get_db), manager = Depends(auth.get_current_manager)):
    entries = crud.get_work_entries(db, skip=0, limit=10000)
    # Build a toy dataset: label by threshold of avg_rate (example only)
    X = []
    y = []
    for e in entries:
        if e.duration_seconds <= 0:
            continue
        avg_rate = e.amount_of_work / (e.duration_seconds/3600)
        label = 2 if avg_rate > 10 else (1 if avg_rate > 3 else 0)
        X.append([e.amount_of_work, e.duration_seconds])
        y.append(label)
    if not X:
        raise HTTPException(status_code=400, detail="Not enough data to train")
    import numpy as np
    X = np.array(X)
    from .ml_model import train_dummy_model
    train_dummy_model(X, y)
    return {"detail": "Model trained and saved."}
